# DedSeg Bot — Environment Variables
# Copy this file to .env and fill in your values

# ── Main Bot (DedSeg Control Bot) ──────────────────────────
BOT_TOKEN=your_main_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# ── GK Quiz Bot ─────────────────────────────────────────────
QUIZ_BOT_TOKEN=your_quiz_bot_token_here
QUIZ_CHAT_ID=-1001234567890

# ── Group IDs (optional — defaults are in config.py) ────────
# GROUP_1_ID=-1001234567890
# GROUP_2_ID=-1001234567891
# GROUP_3_ID=-1001234567892
# GROUP_4_ID=-1001234567893
# GROUP_5_ID=-1001234567894
