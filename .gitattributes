# Normalize line endings to LF for all text files
* text=auto

*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.env   text eol=lf

# Binary files — no line ending conversion
*.db    binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
